{
  "name": "resumeforge",
  "version": "1.6.7",
  "description": "ResumeForge - 简历优化与求职辅助桌面应用",
  "author": "hengtaoshi",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -w -p tsconfig.electron.json\" \"cross-env HTTPS_PROXY=http://127.0.0.1:7897 HTTP_PROXY=http://127.0.0.1:7897 NO_PROXY=localhost,127.0.0.1 electron .\"",
    "build": "tsc -p tsconfig.electron.json && node scripts/generate-icons.mjs && vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "https-proxy-agent": "^9.1.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.resumeforge.app",
    "productName": "ResumeForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ResumeForge"
    },
    "publish": {
      "provider": "github",
      "owner": "hengtaoshi",
      "repo": "resumeforge"
    }
  }
}
